# ─── Railway Environment Variables ──────────────────────────────────────────
# Add these in: Railway Dashboard → Your Service → Variables
#
# Railway auto-provides DATABASE_URL when you add a PostgreSQL plugin.
# Generate JWT secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
JWT_SECRET=generate-a-64-char-random-hex-string
JWT_REFRESH_SECRET=generate-another-64-char-random-hex-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=4000
NODE_ENV=production
CLIENT_URL=https://your-frontend.vercel.app
TOTP_SERVICE_NAME=CyberRange
