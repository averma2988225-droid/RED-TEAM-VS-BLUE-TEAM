generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  RED_TEAM
  BLUE_TEAM
  ADMIN
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SimulationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  username        String    @unique
  password        String
  role            Role      @default(STUDENT)
  avatar          String?
  bio             String?
  securityScore   Int       @default(0)
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  isActive        Boolean   @default(true)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  simulations     Simulation[]
  alerts          Alert[]
  auditLogs       AuditLog[]
  challengeProgress ChallengeProgress[]
  refreshTokens   RefreshToken[]
  codeScans       CodeScan[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Simulation {
  id          String           @id @default(uuid())
  title       String
  type        String
  description String
  status      SimulationStatus @default(PENDING)
  score       Int              @default(0)
  findings    Json?
  userId      String
  createdAt   DateTime         @default(now())
  completedAt DateTime?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Alert {
  id          String    @id @default(uuid())
  title       String
  description String
  severity    Severity
  category    String
  source      String
  isResolved  Boolean   @default(false)
  userId      String
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vulnerability {
  id          String   @id @default(uuid())
  name        String
  cveId       String?  @unique
  severity    Severity
  description String
  solution    String
  category    String
  cvssScore   Float
  createdAt   DateTime @default(now())
}

model Challenge {
  id          String    @id @default(uuid())
  title       String
  description String
  category    String
  difficulty  String
  points      Int
  content     String
  hints       Json?
  solution    String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  progress    ChallengeProgress[]
}

model ChallengeProgress {
  id          String    @id @default(uuid())
  userId      String
  challengeId String
  isCompleted Boolean   @default(false)
  attempts    Int       @default(0)
  score       Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ThreatFeed {
  id          String   @id @default(uuid())
  indicator   String
  type        String
  severity    Severity
  description String
  source      String
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

model CodeScan {
  id          String       @id @default(uuid())
  userId      String
  language    String
  filename    String
  sourceCode  String
  scanType    String       @default("sast")
  status      String       @default("QUEUED")
  score       Int          @default(0)
  summary     Json?
  createdAt   DateTime     @default(now())
  completedAt DateTime?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  findings    ScanFinding[]
}

model ScanFinding {
  id          String   @id @default(uuid())
  scanId      String
  severity    Severity
  ruleId      String
  message     String
  line        Int?
  column      Int?
  code        String?
  fix         String?
  category    String?
  createdAt   DateTime @default(now())
  scan        CodeScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
}
